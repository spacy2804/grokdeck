{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "grokdeck",
  "mainBinaryName": "grokdeck",
  "version": "0.1.0",
  "identifier": "com.spacexai.grokdeck",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Grok Deck",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "desktopTemplate": "assets/grokdeck.desktop"
      },
      "rpm": {
        "desktopTemplate": "assets/grokdeck.desktop"
      }
    }
  }
}
